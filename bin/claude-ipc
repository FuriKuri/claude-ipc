#!/usr/bin/env bash
set -euo pipefail

IPC_BASE="${HOME}/.claude-ipc"
INBOX_DIR="${IPC_BASE}/inbox"
SESSIONS_DIR="${IPC_BASE}/sessions"
PROCESSED_DIR="${IPC_BASE}/processed"

# Ensure directories exist
mkdir -p "$INBOX_DIR" "$SESSIONS_DIR" "$PROCESSED_DIR"

# --- JSON helpers (no jq dependency) ---

json_value() {
  # Extract a value from a flat JSON object: json_value '{"key":"val"}' key
  local json="$1" key="$2"
  echo "$json" | sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1
}

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

make_id() {
  printf '%s-%04x' "$(date +%s)" "$RANDOM"
}

timestamp() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

# --- Subcommands ---

cmd_register() {
  local id="${1:?Usage: claude-ipc register <id> [description]}"
  local desc="${2:-Claude session $id}"
  local pane="${TMUX_PANE:-unknown}"

  mkdir -p "${INBOX_DIR}/${id}"
  mkdir -p "${PROCESSED_DIR}/${id}"

  cat > "${SESSIONS_DIR}/${id}.json" <<ENDJSON
{"id":"${id}","description":"$(json_escape "$desc")","tmux_pane":"${pane}","project":"$(json_escape "$desc")","registered":"$(timestamp)","pid":$$}
ENDJSON

  echo "Session '${id}' registered (pane: ${pane}, project: ${desc})"
}

cmd_send() {
  local to="${1:?Usage: claude-ipc send <to> <type> <payload>}"
  local type="${2:?Missing type (task|result|message|query)}"
  shift 2
  local payload="$*"
  local from="${CLAUDE_IPC_SESSION:-anonymous}"
  local msg_id
  msg_id="$(make_id)"

  mkdir -p "${INBOX_DIR}/${to}"

  local msg_file="${INBOX_DIR}/${to}/${msg_id}.json"
  cat > "$msg_file" <<ENDJSON
{"id":"${msg_id}","from":"$(json_escape "$from")","to":"$(json_escape "$to")","type":"${type}","payload":"$(json_escape "$payload")","timestamp":"$(timestamp)","status":"unread"}
ENDJSON

  # tmux notification if recipient pane is known
  local session_file="${SESSIONS_DIR}/${to}.json"
  if [[ -f "$session_file" ]]; then
    local pane
    pane="$(json_value "$(cat "$session_file")" tmux_pane)"
    if [[ -n "$pane" && "$pane" != "unknown" ]]; then
      tmux display-message -t "$pane" "IPC: New ${type} from ${from}" 2>/dev/null || true
    fi
  fi

  echo "${msg_id}"
}

cmd_read() {
  local id="${1:?Usage: claude-ipc read <id> [--wait] [--timeout=N]}"
  shift
  local wait=false
  local timeout=30

  for arg in "$@"; do
    case "$arg" in
      --wait) wait=true ;;
      --timeout=*) timeout="${arg#--timeout=}" ;;
    esac
  done

  local inbox="${INBOX_DIR}/${id}"
  mkdir -p "$inbox"
  mkdir -p "${PROCESSED_DIR}/${id}"

  _read_messages() {
    local found=false
    for f in "$inbox"/*.json; do
      [[ -f "$f" ]] || continue
      found=true
      cat "$f"
      echo ""
      mv "$f" "${PROCESSED_DIR}/${id}/" 2>/dev/null || true
    done
    $found
  }

  if _read_messages; then
    return 0
  fi

  if $wait; then
    local elapsed=0
    # Try inotifywait first, fall back to polling
    if command -v inotifywait &>/dev/null; then
      inotifywait -q -t "$timeout" -e create "$inbox" &>/dev/null || true
      _read_messages || echo '{"status":"timeout","message":"No messages received within '${timeout}'s"}'
    else
      while (( elapsed < timeout )); do
        sleep 1
        (( elapsed++ ))
        if _read_messages; then
          return 0
        fi
      done
      echo '{"status":"timeout","message":"No messages received within '${timeout}'s"}'
    fi
  else
    echo '{"status":"empty","message":"No messages in inbox for '${id}'"}'
  fi
}

cmd_peek() {
  local id="${1:?Usage: claude-ipc peek <id>}"
  local inbox="${INBOX_DIR}/${id}"
  local count=0

  if [[ ! -d "$inbox" ]]; then
    echo "No inbox for '${id}'"
    return 0
  fi

  for f in "$inbox"/*.json; do
    [[ -f "$f" ]] || continue
    (( count++ ))
    local content
    content="$(cat "$f")"
    local from type payload ts
    from="$(json_value "$content" from)"
    type="$(json_value "$content" type)"
    payload="$(json_value "$content" payload)"
    ts="$(json_value "$content" timestamp)"
    echo "[${count}] ${ts} | ${type} from ${from}: ${payload:0:80}"
  done

  if (( count == 0 )); then
    echo "Inbox empty for '${id}'"
  else
    echo "--- ${count} message(s) ---"
  fi
}

cmd_list() {
  local id="${1:-}"

  if [[ -n "$id" ]]; then
    cmd_peek "$id"
    return
  fi

  echo "=== Inboxes ==="
  for d in "$INBOX_DIR"/*/; do
    [[ -d "$d" ]] || continue
    local name
    name="$(basename "$d")"
    local count=0
    for f in "$d"*.json; do [[ -f "$f" ]] && (( count++ )); done
    echo "  ${name}: ${count} message(s)"
  done
}

cmd_sessions() {
  echo "=== Registered Sessions ==="
  for f in "$SESSIONS_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    local content
    content="$(cat "$f")"
    local id desc pane reg
    id="$(json_value "$content" id)"
    desc="$(json_value "$content" description)"
    pane="$(json_value "$content" tmux_pane)"
    project="$(json_value "$content" project)"
    reg="$(json_value "$content" registered)"
    echo "  ${id} (pane: ${pane}) — ${project} [${reg}]"
  done
}

cmd_clear() {
  local id="${1:?Usage: claude-ipc clear <id>}"
  local inbox="${INBOX_DIR}/${id}"
  if [[ -d "$inbox" ]]; then
    rm -f "$inbox"/*.json
    echo "Inbox cleared for '${id}'"
  else
    echo "No inbox for '${id}'"
  fi
}

cmd_inject() {
  local target="${1:?Usage: claude-ipc inject <tmux-target> <text>}"
  shift
  local text="$*"
  tmux send-keys -t "$target" "$text" Enter
}

cmd_watch() {
  local id="${1:?Usage: claude-ipc watch <id>}"
  local inbox="${INBOX_DIR}/${id}"
  mkdir -p "$inbox"

  echo "Watching inbox for '${id}' (Ctrl+C to stop)..."

  if command -v inotifywait &>/dev/null; then
    while true; do
      inotifywait -q -e create "$inbox" &>/dev/null
      for f in "$inbox"/*.json; do
        [[ -f "$f" ]] || continue
        cat "$f"
        echo ""
      done
    done
  else
    # Polling fallback
    while true; do
      for f in "$inbox"/*.json; do
        [[ -f "$f" ]] || continue
        cat "$f"
        echo ""
      done
      sleep 1
    done
  fi
}

cmd_reset() {
  rm -rf "${INBOX_DIR:?}"/* "${SESSIONS_DIR:?}"/* "${PROCESSED_DIR:?}"/*
  echo "IPC state reset."
}

cmd_help() {
  cat <<'EOF'
claude-ipc — IPC for Claude Code sessions in tmux

Usage: claude-ipc <command> [args]

Commands:
  register <id> [desc]         Register this session
  send <to> <type> <payload>   Send a message (type: task|result|message|query)
  read <id> [--wait] [--timeout=N]  Read & consume messages
  peek <id>                    Preview inbox without consuming
  list [id]                    List all inboxes or one specific
  sessions                     Show registered sessions
  clear <id>                   Clear an inbox
  inject <tmux-target> <text>  Send keystrokes to a tmux pane
  watch <id>                   Live-watch an inbox
  reset                        Clear all IPC state

Environment:
  CLAUDE_IPC_SESSION    Your session ID (set automatically by claude-sessions)
EOF
}

# --- Main dispatch ---

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  register)  cmd_register "$@" ;;
  send)      cmd_send "$@" ;;
  read)      cmd_read "$@" ;;
  peek)      cmd_peek "$@" ;;
  list)      cmd_list "$@" ;;
  sessions)  cmd_sessions "$@" ;;
  clear)     cmd_clear "$@" ;;
  inject)    cmd_inject "$@" ;;
  watch)     cmd_watch "$@" ;;
  reset)     cmd_reset "$@" ;;
  help|--help|-h) cmd_help ;;
  *)         echo "Unknown command: $cmd"; cmd_help; exit 1 ;;
esac
