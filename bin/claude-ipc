#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
claude-ipc — Discover and trigger sibling Claude sessions in tmux

Usage:
  claude-ipc list                      List all other Claude panes
  claude-ipc trigger <id> <prompt>     Send a prompt to another pane by directory basename

Discovers all tmux panes running Claude across all sessions and windows.
Panes are identified by the basename of their working directory.
EOF
  exit 1
}

# Find tmux socket — needed when TMUX env is not inherited (e.g. Claude Code shells)
find_tmux() {
  if tmux list-sessions &>/dev/null; then
    return 0
  fi
  local socket
  socket=$(find "/private/tmp/tmux-$(id -u)" "/tmp/tmux-$(id -u)" -type s 2>/dev/null | head -1)
  if [ -n "$socket" ]; then
    export TMUX_TMPDIR="${socket%/*}"
    alias tmux="tmux -S '$socket'"
    return 0
  fi
  echo "Error: no tmux server found. Claude sessions must run inside tmux."
  exit 1
}

# Get own pane ID (empty if not running inside a tmux pane)
get_self_pane() {
  tmux display-message -p '#{pane_id}' 2>/dev/null || echo ""
}

# List all tmux panes excluding self
list_panes() {
  local self
  self=$(get_self_pane)

  tmux list-panes -a -F '#{pane_id} #{pane_current_path}' | while read -r id path; do
    [ "$id" = "$self" ] && continue
    echo "$(basename "$path")  ->  $path  ($id)"
  done
}

# Find pane IDs matching a target basename
find_target_panes() {
  local target="$1"
  local self
  self=$(get_self_pane)

  tmux list-panes -a -F '#{pane_id} #{pane_current_path}' | while read -r id path; do
    [ "$id" = "$self" ] && continue
    if [ "$(basename "$path")" = "$target" ]; then
      echo "$id $path"
    fi
  done
}

trigger_pane() {
  local target="$1"
  shift
  local prompt="$*"

  local matches
  matches=$(find_target_panes "$target")

  if [ -z "$matches" ]; then
    echo "Error: no Claude pane found for '$target'"
    echo ""
    echo "Available:"
    list_panes
    exit 1
  fi

  local count
  count=$(echo "$matches" | wc -l | tr -d ' ')

  if [ "$count" -gt 1 ]; then
    echo "Multiple panes match '$target':"
    echo ""
    local i=1
    echo "$matches" | while read -r id path; do
      echo "  $i) $path  ($id)"
      i=$((i + 1))
    done
    echo ""
    echo "Use the full pane ID to target a specific one:"
    echo "  claude-ipc trigger-pane <pane_id> <prompt>"
    exit 1
  fi

  local pane_id
  pane_id=$(echo "$matches" | awk '{print $1}')

  tmux send-keys -t "$pane_id" "$prompt" Enter
  echo "Sent to $target ($pane_id)"
}

trigger_by_pane_id() {
  local pane_id="$1"
  shift
  local prompt="$*"
  tmux send-keys -t "$pane_id" "$prompt" Enter
  echo "Sent to $pane_id"
}

find_tmux

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  list)         list_panes ;;
  trigger)
    [ $# -lt 2 ] && { echo "Usage: claude-ipc trigger <id> <prompt>"; exit 1; }
    trigger_pane "$@"
    ;;
  trigger-pane)
    [ $# -lt 2 ] && { echo "Usage: claude-ipc trigger-pane <pane_id> <prompt>"; exit 1; }
    trigger_by_pane_id "$@"
    ;;
  *)            usage ;;
esac
