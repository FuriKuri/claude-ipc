#!/usr/bin/env bash
set -euo pipefail

LAYOUT="tiled"
SESSION_NAME="claude-multi"
PROJECTS=()
SESSIONS_DIR="${HOME}/.claude-ipc"

# Parse args
for arg in "$@"; do
  case "$arg" in
    --layout=*)  LAYOUT="${arg#--layout=}" ;;
    --name=*)    SESSION_NAME="${arg#--name=}" ;;
    --help|-h)
      cat <<'EOF'
claude-sessions — Launch multiple Claude Code instances in tmux

Usage: claude-sessions [options] <dir1> [dir2] [dir3] ...

Each directory gets its own tmux pane running Claude Code.
Session IDs are derived from directory names (e.g. ~/Projects/api -> api).
Use /ipc-trigger inside Claude to send prompts to other panes.

Options:
  --layout=tiled|vertical|horizontal   Pane layout (default: tiled)
  --name=<name>                        tmux session name (default: claude-multi)

Examples:
  claude-sessions ~/Projects/api ~/Projects/frontend
  claude-sessions --layout=vertical ./backend ./frontend ./shared
  claude-sessions .
EOF
      exit 0
      ;;
    -*)  echo "Unknown option: $arg"; exit 1 ;;
    *)   PROJECTS+=("$arg") ;;
  esac
done

if (( ${#PROJECTS[@]} == 0 )); then
  echo "Usage: claude-sessions [options] <dir1> [dir2] ..."
  exit 1
fi

COUNT=${#PROJECTS[@]}

# Resolve directories and derive session IDs
RESOLVED_DIRS=()
SESSION_IDS=()
for dir in "${PROJECTS[@]}"; do
  resolved="$(cd "$dir" 2>/dev/null && pwd)" || { echo "Directory not found: $dir"; exit 1; }
  RESOLVED_DIRS+=("$resolved")
  sid="$(basename "$resolved")"
  # Deduplicate by appending number if needed
  count=0
  original_sid="$sid"
  while printf '%s\n' "${SESSION_IDS[@]}" 2>/dev/null | grep -qx "$sid"; do
    (( count++ ))
    sid="${original_sid}${count}"
  done
  SESSION_IDS+=("$sid")
done

# Clean up old session state
mkdir -p "$SESSIONS_DIR"
rm -f "$SESSIONS_DIR"/*.pane

# Kill existing tmux session if present
tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true

# Create tmux session with first pane
tmux new-session -d -s "$SESSION_NAME" -x 200 -y 50

# Create additional panes
for (( i=1; i<COUNT; i++ )); do
  case "$LAYOUT" in
    vertical)   tmux split-window -t "$SESSION_NAME" -v ;;
    horizontal) tmux split-window -t "$SESSION_NAME" -h ;;
    *)          tmux split-window -t "$SESSION_NAME" ;;
  esac
done

tmux select-layout -t "$SESSION_NAME" "$LAYOUT" 2>/dev/null || tmux select-layout -t "$SESSION_NAME" tiled

# Enable pane border labels
tmux set-option -t "$SESSION_NAME" pane-border-status top 2>/dev/null || true
tmux set-option -t "$SESSION_NAME" pane-border-format " #{pane_index}: #{pane_title} " 2>/dev/null || true

# Configure each pane: set env, write pane mapping, start claude
for (( i=0; i<COUNT; i++ )); do
  sid="${SESSION_IDS[$i]}"
  dir="${RESOLVED_DIRS[$i]}"
  pane_target="${SESSION_NAME}:0.${i}"

  tmux select-pane -t "$pane_target" -T "${sid}" 2>/dev/null || true

  # Write pane mapping for /ipc-trigger
  echo "$pane_target" > "${SESSIONS_DIR}/${sid}.pane"

  # Set environment and start claude
  tmux send-keys -t "$pane_target" "export CLAUDE_IPC_SESSION='${sid}'" Enter
  tmux send-keys -t "$pane_target" "cd '${dir}' && claude" Enter
done

echo "Starting '${SESSION_NAME}' with ${COUNT} panes..."
echo ""
for (( i=0; i<COUNT; i++ )); do
  echo "  ${SESSION_IDS[$i]}  ->  ${RESOLVED_DIRS[$i]}"
done
echo ""
echo "Use /ipc-trigger <session-id> <prompt> inside Claude to communicate."
echo ""

tmux attach -t "$SESSION_NAME"
